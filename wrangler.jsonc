{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "ai-agentdock",
  "compatibility_date": "2026-07-05",
  "observability": {
    "enabled": true
  },
  "build": {
    "command": "node scripts/build.js && node scripts/verify-dist.js"
  },
  "assets": {
    "directory": "./dist",
    "not_found_handling": "404-page"
  },
  "compatibility_flags": ["nodejs_compat"]
}
